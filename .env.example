# Copy to .env and fill values. Never commit .env.

# market_data_provider: yahoo | eodhd
MARKET_DATA_PROVIDER=yahoo

# Required when MARKET_DATA_PROVIDER=eodhd (https://eodhd.com/)
EODHD_API_KEY=

# Agent 1 news intake (reference app uses GNews API).
GNEWS_API_KEY=
NEWS_TRUSTED_SOURCES_ONLY=true

# SQLite path for Agent 1 and future entities.
DATABASE_URL=data/finhack.db

# Optional: custom ticker aliases for Agent 2 exposure matching.
# JSON shape: { "NVDA": ["nvidia corp", "blackwell"], "MSFT": ["microsoft"] }
TICKER_ALIASES_PATH=ticker_aliases.example.json

# Optional: LLM for chatbot (replace stub in session_chatbot.py)
# OPENAI_API_KEY=
