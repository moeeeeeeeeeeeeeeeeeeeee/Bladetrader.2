# Copy to .env and fill values. Never commit .env.

# Required: EODHD is the only supported market-data provider (https://eodhd.com/)
EODHD_API_KEY=

# EODHD tuning (optional)
MARKET_DATA_CACHE_TTL_SECONDS=300
MARKET_DATA_LIVE_CACHE_TTL_SECONDS=15
MARKET_DATA_SYMBOLS_CACHE_TTL_SECONDS=3600

# News intake (GNews + GDELT + RSS + EODHD).
GNEWS_API_KEY=
NEWS_TRUSTED_SOURCES_ONLY=true
NEWS_REQUIRE_GNEWS=false
NEWS_REQUIRE_PRIMARY_API=true
NEWS_ENABLE_GDELT=true
NEWS_ENABLE_RSS_FALLBACK=true
# Use EODHD /api/news for live + backtest news when EODHD_API_KEY is set
NEWS_ENABLE_EODHD=true

# SQLite path for the news + research store.
DATABASE_URL=data/finhack.db

# Research/trading universe size (EODHD US common stocks + core mapped names).
TRADING_UNIVERSE_LIMIT=500
# Historical news backfill depth for validate_case4_earnings.py
NEWS_BACKFILL_DAYS=730
